{
  "manifest_version": 3,
  "name": "DMS - Tools",
  "version": "1.1",
  "description": "DMS additional tools for better performance",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "DMS - Tools"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.dms-siasn.bkn.go.id/*"],
      "css": ["dark.css"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}